  "description": "SEO-optimized industrial fault code library",
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "postinstall": "prisma generate || echo 'prisma generate skipped'",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "npx tsx prisma/seed.ts",
    "list-modules": "npx tsx scripts/list-modules.ts",
    "list-modules:flat": "npx tsx scripts/list-modules.ts --flat",
    "db:cleanup-orphan-codes": "npx tsx scripts/cleanup-orphan-fault-codes.ts",
    "db:cleanup-orphan-codes:execute": "npx tsx scripts/cleanup-orphan-fault-codes.ts --execute",
    "db:backfill-series-display": "npx tsx scripts/backfill-series-display.ts",
    "db:backfill-series-display:execute": "npx tsx scripts/backfill-series-display.ts --execute",
    "db:strip-ac-drives": "npx tsx scripts/strip-ac-drives-manual-names.ts",
    "db:strip-ac-drives:execute": "npx tsx scripts/strip-ac-drives-manual-names.ts --execute",
    "db:cleanup-brands": "npx tsx scripts/cleanup-brands-migration.ts",
    "db:cleanup-brands:execute": "npx tsx scripts/cleanup-brands-migration.ts --execute",
    "db:cleanup-db": "npx tsx scripts/cleanup-db.ts",
    "db:cleanup-db:execute": "npx tsx scripts/cleanup-db.ts --execute",
    "db:audit": "npx tsx scripts/audit-content.ts",
    "db:repair": "npx tsx scripts/backfill-fix-steps.ts",
    "process-manual": "npx tsx scripts/process-manual.ts",
    "mine": "npx tsx scripts/auto-miner.ts",
    "push-google": "npx tsx scripts/push-to-google.ts"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
